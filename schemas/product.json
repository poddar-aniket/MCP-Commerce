{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductQuery",
  "type": "object",
  "required": ["query"],
  "properties": {
    "category": {
      "type": ["string", "null"],
      "description": "Product category (e.g. smartphone, shoe)"
    },
    "brand": {
      "type": ["string", "null"],
      "description": "Brand name if known"
    },
    "query": {
      "type": "string",
      "description": "Normalized product query string"
    },
    "color": {
      "type": ["string", "null"],
      "description": "Primary product color"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Other product-specific attributes like storage, size, RAM"
    }
  }
}
